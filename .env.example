# Stripe 連携用の環境変数
# Vercel ダッシュボード → Project Settings → Environment Variables に同名で設定。
# テストモードと本番（Live モード）で値が変わるので、Production / Preview / Development の
# 3 環境それぞれに設定してください。

# === API キー ===
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# === Webhook 署名シークレット ===
# Stripe ダッシュボード → 開発者 → Webhooks → エンドポイント追加で
# https://<本番ドメイン>/api/stripe-webhook を登録した後に発行される whsec_...
STRIPE_WEBHOOK_SECRET=whsec_...

# === Price ID（subscription 用） ===
# 商品カタログで Product を作成し、その Recurring Price ID を貼る。
# テストモードと本番モードで別 ID になるため、環境ごとに切り替えること。

# 正会員（個人・団体）10,000円/年
STRIPE_PRICE_MEMBER_FULL=price_...

# 賛助会員（個人）5,000円/口/年
STRIPE_PRICE_MEMBER_ASSOC_INDIV=price_...

# 賛助会員（団体・法人）5,000円/口/年
STRIPE_PRICE_MEMBER_ASSOC_ORG=price_...

# マンスリーサポーター 月額 1,000円
STRIPE_PRICE_MONTHLY_1K=price_...

# マンスリーサポーター 月額 3,000円
STRIPE_PRICE_MONTHLY_3K=price_...

# マンスリーサポーター 月額 5,000円
STRIPE_PRICE_MONTHLY_5K=price_...

# マンスリーサポーター 月額 10,000円
STRIPE_PRICE_MONTHLY_10K=price_...

# === サイト URL ===
# Checkout 後の戻り先（success_url / cancel_url）に使う。
# ローカル開発：http://localhost:3000
# 本番：https://open-mic-japan.vercel.app（独自ドメイン化したら差し替え）
NEXT_PUBLIC_SITE_URL=https://open-mic-japan.vercel.app
